{
  "schemaVersion": "1.0",
  "configId": "mbddf-system-status",
  "productModel": "MB_DDF_v2",
  "productName": "MB_DDF system status",
  "configVersion": "1.0.0",
  "steps": [
    {
      "stepId": "SYSTEM_STATUS",
