      "name": "Read system status",
      "type": "EXCHANGE",
      "algorithmId": "mbddf.system_status",
      "parameters": {
        "protocol": {
          "requestValues": {}
        }
      },
      "timeoutMs": 2000,
      "retryCount": 0,
      "enabled": true,
      "dependsOn": [],
      "criteria": [
        {
          "metric": "status",
          "op": "Equal",
          "ref": 0,
          "tol": 0,
          "passIfMatched": true
        },
        {
          "metric": "err_code",
          "op": "Equal",
          "ref": 0,
          "tol": 0,
          "passIfMatched": true
        }
      ]
    }
  ],
  "hardwareRequirements": [],
